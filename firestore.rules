rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Note: Open rules for CRM. In production, restrict to admin emails.
    match /loans/{loan} {
      allow read, write: if request.auth != null;
    }
    match /entries/{entry} {
      allow read, write: if request.auth != null;
    }
  }
}

{
  "entities": {
    "Loan": {
      "title": "Loan",
      "description": "Represents a loan given to a customer.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string", "description": "Full Name" },
        "phoneNumber": { "type": "string", "description": "Phone Number" },
        "address": { "type": "string", "description": "Address" },
        "referencePerson": { "type": "string", "description": "Reference Person" },
        "principalAmount": { "type": "number", "description": "Principal amount" },
        "interestRate": { "type": "number", "description": "Interest rate" },
        "durationDays": { "type": "number", "description": "Duration in days" },
        "startDate": { "type": "string", "description": "Start date iso string" },
        "dueDate": { "type": "string", "description": "Due date iso string" },
        "totalAmount": { "type": "number", "description": "Total amount with interest" },
        "remainingAmount": { "type": "number", "description": "Remaining amount to pay" },
        "status": { "type": "string", "enum": ["pending", "active", "overdue", "default", "closed", "rejected"] },
        "createdAt": { "type": "number", "description": "Timestamp" },
        "updatedAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["customerName", "phoneNumber", "address", "principalAmount", "interestRate", "durationDays", "status"]
      },
    "Entry": {
      "title": "Entry",
      "description": "Payment or charge applied to a loan.",
      "type": "object",
      "properties": {
        "loanId": { "type": "string", "description": "The loop id" },
        "amount": { "type": "number", "description": "Entry amount" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "date": { "type": "number", "description": "Timestamp" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["loanId", "amount", "type"]
    }
  },
  "firestore": {
    "loans": {
      "schema": { "$ref": "#/entities/Loan" },
      "description": "All loans."
    },
    "entries": {
       "schema": { "$ref": "#/entities/Entry" },
       "description": "All transactions/entries."
    }
  }
}
